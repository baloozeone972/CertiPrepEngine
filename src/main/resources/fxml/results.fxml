<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="com.certiprep.ui.ResultsController" spacing="15" styleClass="results-container">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Text fx:id="resultTitle" text="Résultats" styleClass="title"/>

    <!-- Score principal -->
    <HBox spacing="30" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5">
            <Text fx:id="scoreText" text="0/0" styleClass="score-big"/>
            <Text fx:id="percentageText" text="0%" styleClass="score-percent"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5">
            <Text fx:id="statusText" text="En attente" styleClass="status-big"/>
            <Text fx:id="timeText" text="00:00:00" styleClass="time-text"/>
        </VBox>
    </HBox>

    <!-- Tableau détail thèmes -->
    <Label text="Détail par thème" styleClass="section-title"/>
    <TableView fx:id="themeTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="themeCol" text="Thème" prefWidth="250"/>
            <TableColumn fx:id="correctCol" text="Correct" prefWidth="80"/>
            <TableColumn fx:id="totalCol" text="Total" prefWidth="80"/>
            <TableColumn fx:id="percentCol" text="pourcentage" prefWidth="80"/>
        </columns>
    </TableView>

    <!-- Boutons actions -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="exportPdfBtn" text="Exporter PDF" styleClass="primary-btn" prefWidth="120"/>
        <Button fx:id="reviewWrongBtn" text="Revoir les erreurs" styleClass="secondary-btn" prefWidth="150"/>
        <Button fx:id="newExamBtn" text="Nouvel examen" styleClass="secondary-btn" prefWidth="120"/>
        <Button fx:id="closeBtn" text="Fermer" styleClass="danger-btn" prefWidth="100"/>
    </HBox>
</VBox>